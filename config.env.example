# ── Required ──────────────────────────────────────────────────────────────────
# Telegram API credentials from https://my.telegram.org/apps
API_ID=1234567
API_HASH=your_api_hash_here

# Bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Your numeric Telegram user ID (owner). Get it from @userinfobot
OWNER_ID=11111111

# Chat/channel where files are uploaded. Bot must be admin there.
DUMP_CHAT_ID=-1001234567890

# ── rclone config (choose ONE) ────────────────────────────────────────────────
# Option A: a URL to a raw rclone.conf (e.g. a GitHub gist /raw link)
# RCLONE_CONF_URL=https://gist.github.com/you/abc123/raw

# Option B: inline rclone.conf with literal \n between lines
# RCLONE_CONF=[Dropbox32]\ntype = dropbox\ntoken = {...}

# Option C: mount a file at /root/.config/rclone/rclone.conf (Docker volume)

# ── Optional ──────────────────────────────────────────────────────────────────
# Extra authorized user IDs (comma or semicolon separated). Owner is always allowed.
# AUTHORIZED_USERS=22222222,33333333

# Where files are temporarily downloaded
DOWNLOAD_DIR=/tmp/rclone_dl

# Extra flags appended to every rclone command
# RCLONE_FLAGS=--drive-chunk-size 64M

# Split threshold in bytes (default ~1.99 GB for non-premium Telegram)
SPLIT_SIZE=2044723200

# Concurrent files per job (1-5). Use 1 for large files.
CONCURRENT_JOBS=1

# rclone download bandwidth limit (e.g. 8M, 512k, 1G) or leave empty for unlimited
# BW_LIMIT=8M

# Health check HTTP port
HEALTH_PORT=8080

# Seconds between Telegram board edits (2-30)
BOARD_REFRESH_INTERVAL=8.0

# Where persisted stats are stored
STATS_FILE=/tmp/rclone_bot_stats.json

# ffmpeg CPU pinning / threads (optional)
CPU_CORES=0
# CPU_THREADS=4
